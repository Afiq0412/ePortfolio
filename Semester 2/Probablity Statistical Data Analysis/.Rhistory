data1
n <- 579
alpha <- 0.05
mu <- 30.0
# Calculate mean and standard deviation
xdata <- mean(data1)
datasd <- sd(data1)
# Calculate Z statistics
z <- (xdata-mu) / (datasd/sqrt(n))
# Calculate critical value
z.alpha <- qnorm(1-alpha/2)
# Calculate c.v on both side
c(-z.alpha, z.alpha)
